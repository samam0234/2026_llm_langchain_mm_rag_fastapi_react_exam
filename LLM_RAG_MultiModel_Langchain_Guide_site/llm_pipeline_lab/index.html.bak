    <!-- Detailed MD Link -->
    <div id="detailed-md" class="max-w-screen-2xl mx-auto px-8 pb-20">
        <div class="max-w-3xl mx-auto text-center py-12 border-t border-white/10">
            <p class="text-zinc-400">더 깊이 있는 변수 설명, 코드 흐름, 출력 결과 분석은 아래 파일에서 확인하세요.</p>
            <a href="../2026_llm_langchain_rag_exam_코드설명.md" 
               class="inline-flex items-center gap-x-3 mt-6 px-8 py-3.5 rounded-3xl border border-white/30 hover:bg-white/5 transition-all text-sm font-medium">
                <i class="fa-solid fa-file-alt"></i>
                <span>상세 분석 MD 파일 열기 (2026_llm_langchain_rag_exam_코드설명.md)</span>
            </a>
        </div>
    </div>

    <footer class="border-t border-white/10 py-8 text-center text-xs text-zinc-500">
        ShadowWatch AI • BiNCS 2026 LLM·LangChain 실습 프로젝트<br>
        이 사이트는 교육용으로 제작되었습니다.
    </footer>

    <script>
        // Tailwind script
        function initializeTailwind() {
            document.documentElement.style.setProperty('--accent', '#6366f1');
        }
        
        // Highlight pipeline step
        let currentStep = -1;
        
        function highlightStep(stepIndex) {
            const steps = document.querySelectorAll('#pipeline-container .pipeline-step');
            
            // Reset all
            steps.forEach((step, idx) => {
                step.classList.remove('active', 'border-indigo-500');
                step.style.borderColor = '';
            });
            
            if (stepIndex === currentStep) {
                currentStep = -1;
                return;
            }
            
            const target = steps[stepIndex];
            if (target) {
                target.classList.add('active', 'border-indigo-500');
                target.style.borderColor = '#6366f1';
                currentStep = stepIndex;
                
                // Auto scroll on mobile
                if (window.innerWidth < 768) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
        }
        
        // Pipeline animation
        function startPipelineAnimation() {
            const arrows = document.querySelectorAll('.flow-arrow');
            const steps = document.querySelectorAll('#pipeline-container .pipeline-step');
            
            // Reset
            arrows.forEach(a => a.classList.remove('active', 'text-indigo-400'));
            steps.forEach(s => s.classList.remove('active', 'border-indigo-500'));
            
            let i = 0;
            const interval = setInterval(() => {
                if (i > 0) {
                    arrows[i-1].classList.remove('active', 'text-indigo-400');
                    steps[i-1].classList.remove('active', 'border-indigo-500');
                }
                
                if (i < steps.length) {
                    steps[i].classList.add('active', 'border-indigo-500');
                    if (arrows[i]) arrows[i].classList.add('active', 'text-indigo-400');
                    i++;
                } else {
                    clearInterval(interval);
                    // Reset after finish
                    setTimeout(() => {
                        steps.forEach(s => s.classList.remove('active', 'border-indigo-500'));
                        arrows.forEach(a => a.classList.remove('active', 'text-indigo-400'));
                    }, 1200);
                }
            }, 650);
        }
        
        // Demo Analysis Simulation
        function runDemoAnalysis() {
            const outputDiv = document.getElementById('demo-output');
            const location = document.getElementById('location').value;
            const frameId = document.getElementById('frame_id').value;
            const timestamp = document.getElementById('timestamp').value;
            const detectionType = document.getElementById('detection_type').value;
            
            outputDiv.innerHTML = `
                <div class="flex items-center gap-x-2 text-emerald-400 mb-4">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <span class="font-medium">LLM 분석 중...</span>
                </div>
            `;
            
            setTimeout(() => {
                let riskLevel = "주의";
                let reason = `${location}에서 ${timestamp}에 탐지된 객체를 분석한 결과, 사람의 움직임이 감지되었습니다.`;
                let action = "추가 확인이 필요합니다. 근처 카메라 영상을 확인하세요.";
                
                if (detectionType === "suspicious") {
                    riskLevel = "위험";
                    reason = "수상한 움직임이 다수 탐지되었습니다. 비정상적인 행동 패턴이 감지됨.";
                    action = "즉시 보안 요원 파견 및 경찰 신고를 권장합니다.";
                } else if (detectionType === "vehicle") {
                    riskLevel = "주의";
                    reason = "차량과 함께 사람이 탐지되었습니다. 야간 출입 차량 확인이 필요합니다.";
                }
                
                const result = {
                    frame_id: parseInt(frameId),
                    timestamp: timestamp,
                    location: location,
                    risk_level: riskLevel,
                    reason: reason,
                    action: action,
                    confidence: "0.89",
                    analyzed_at: new Date().toISOString()
                };
                
                outputDiv.innerHTML = `
                    <div class="text-emerald-400 text-xs mb-2 flex items-center gap-x-2">
                        <i class="fa-solid fa-check-circle"></i> 
                        <span>분석 완료 (시뮬레이션)</span>
                    </div>
                    <pre class="text-xs leading-relaxed text-zinc-300 whitespace-pre-wrap">${JSON.stringify(result, null, 2)}</pre>
                    
                    <div class="mt-4 pt-4 border-t border-white/10 flex items-center justify-between text-[10px]">
                        <div class="text-zinc-500">Memory에 저장됨</div>
                        <div class="px-3 py-0.5 bg-emerald-900/30 text-emerald-400 rounded-full text-[10px]">risk_level: ${riskLevel}</div>
                    </div>
                `;
            }, 1350);
        }
        
        // Full simulation from pipeline (triggers demo + animation)
        function startSimulation() {
            // Scroll to demo
            document.getElementById('demo').scrollIntoView({ behavior: 'smooth', block: 'start' });
            
            setTimeout(() => {
                // Pre-fill demo with interesting values
                document.getElementById('location').value = "주차장 B구역";
                document.getElementById('frame_id').value = "12";
                document.getElementById('timestamp').value = "03:11";
                document.getElementById('detection_type').value = "suspicious";
                
                // Run analysis
                runDemoAnalysis();
                
                // Also animate the pipeline
                setTimeout(() => {
                    startPipelineAnimation();
                }, 800);
            }, 900);
        }
        
        // Keyboard support
        function setupKeyboard() {
            document.addEventListener('keydown', function(e) {
                if (e.key === "?" && document.activeElement.tagName === "BODY") {
                    e.preventDefault();
                    const demo = document.getElementById('demo');
                    demo.scrollIntoView({ behavior: 'smooth' });
                }
                
                if (e.key.toLowerCase() === 'r' && e.metaKey) {
                    e.preventDefault();
                    startPipelineAnimation();
                }
            });
            
            // Easter egg: click logo to reset
            const logo = document.querySelector('.fa-shield-halved');
            if (logo) {
                logo.addEventListener('click', () => {
                    document.querySelectorAll('.pipeline-step').forEach(s => s.classList.remove('active', 'border-indigo-500'));
                    document.querySelectorAll('.flow-arrow').forEach(a => a.classList.remove('active', 'text-indigo-400'));
                });
            }
        }
        
        // Initialize everything
        function init() {
            initializeTailwind();
            setupKeyboard();
            
            // Random subtle animation on load for one step
            setTimeout(() => {
                const firstStep = document.querySelector('#pipeline-container .pipeline-step');
                if (firstStep) {
                    firstStep.style.transitionDuration = '0ms';
                    firstStep.classList.add('border-indigo-500/30');
                    setTimeout(() => {
                        firstStep.style.transitionDuration = '0.4s';
                        firstStep.classList.remove('border-indigo-500/30');
                    }, 300);
                }
            }, 2200);
            
            // Make pipeline steps keyboard accessible
            const steps = document.querySelectorAll('#pipeline-container .pipeline-step');
            steps.forEach((step, index) => {
                step.setAttribute('tabindex', '0');
                step.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        highlightStep(index);
                    }
                });
            });
            
            console.log('%c[ShadowWatch] LLM Pipeline Lab initialized', 'color:#666');
        }
        
        // ==================== PYODIDE + ADVANCED INTERACTIVE DEMO ====================
        let pyodide = null;
        let pyodideReady = false;
        let currentCategory = 'part01-basic';

        // Pyodide 로더
        async function loadPyodideIfNeeded() {
            if (pyodideReady) return pyodide;

            const statusEl = document.getElementById('pyodide-status');
            if (statusEl) statusEl.textContent = 'Pyodide 로딩 중... (처음에는 10~20초 정도 걸릴 수 있습니다)';

            try {
                pyodide = await loadPyodide({
                    indexURL: "https://cdn.jsdelivr.net/pyodide/v0.26.4/full/"
                });

                // 기본 패키지 로드 (필요한 경우)
                await pyodide.loadPackagesFromImports(`
                    import json
                    import re
                `);

                pyodideReady = true;
                if (statusEl) {
                    statusEl.textContent = '✅ Pyodide 준비 완료';
                    statusEl.classList.add('text-emerald-400');
                }
                console.log('%c[Pyodide] Ready', 'color:#22c55e');
                return pyodide;
            } catch (err) {
                console.error('Pyodide 로딩 실패:', err);
                if (statusEl) statusEl.textContent = 'Pyodide 로딩 실패 (일부 기능이 제한됩니다)';
                return null;
            }
        }

        // Python 코드 실행 + stdout 캡처
        async function runPythonCode(code) {
            const py = await loadPyodideIfNeeded();
            if (!py) {
                return { success: false, output: "Pyodide를 로드할 수 없습니다. 인터넷 연결을 확인해주세요." };
            }

            try {
                // stdout 리디렉션 설정
                py.runPython(`
                    import sys
                    from io import StringIO
                    sys.stdout = StringIO()
                `);

                await py.runPythonAsync(code);

                const output = py.runPython("sys.stdout.getvalue()");
                return { success: true, output: output || "(출력 없음)" };
            } catch (err) {
                return { success: false, output: String(err) };
            }
        }

        const categoryConfig = {
            'part01-basic': {
                label: 'Part01 - Basic Completion',
                description: '기본 Chat Completion + System Prompt',
                inputs: [
                    { id: 'location', label: '위치', type: 'text', value: '창고 출입구' },
                    { id: 'timestamp', label: '시각', type: 'text', value: '02:47' },
                    { id: 'detections', label: '탐지 내용', type: 'text', value: 'person 2명' }
                ],
                run: runPart01Basic
            },
            'part02-lcel': {
                label: 'Part02 - LCEL Chain',
                description: 'LCEL + JsonOutputParser',
                inputs: [
                    { id: 'frame_id', label: 'Frame ID', type: 'number', value: '42' },
                    { id: 'location', label: '위치', type: 'text', value: '주차장 A구역' },
                    { id: 'detections', label: '탐지 내용', type: 'text', value: 'person:2, car:1' }
                ],
                run: runPart02LCEL
            },
            'part03-rag': {
                label: 'Part03 - RAG Pipeline',
                description: 'Retriever + Context + Generation',
                inputs: [
                    { id: 'query', label: '질문', type: 'text', value: '새벽에 창고에서 침입 의심 사례 알려줘' }
                ],
                run: runPart03RAG
            },
            'part04-diarization': {
                label: 'Part04 - Speaker Diarization',
                description: 'Whisper + pyannote 화자 분리',
                inputs: [
                    { id: 'audio_name', label: '오디오 파일', type: 'text', value: '20260526_All_units.wav' }
                ],
                run: runPart04Diarization
            },
            'part04-vision': {
                label: 'Part04 - Vision Analysis',
                description: 'GPT-4o Vision 이미지 분석',
                inputs: [
                    { id: 'image_desc', label: '이미지 설명 (시뮬레이션)', type: 'text', value: '주차장에서 두 사람이 차량 주변을 배회하는 모습' }
                ],
                run: runPart04Vision
            }
        };

        function selectCategory(category) {
            currentCategory = category;
            
            // Update tab styles
            document.querySelectorAll('.category-tab').forEach(tab => {
                if (tab.dataset.category === category) {
                    tab.classList.add('active', 'bg-white', 'text-zinc-900');
                    tab.classList.remove('bg-zinc-800');
                } else {
                    tab.classList.remove('active', 'bg-white', 'text-zinc-900');
                    tab.classList.add('bg-zinc-800');
                }
            });

            renderDynamicForm(category);
            
            // Clear previous outputs
            document.getElementById('prompt-output').innerHTML = `<div class="text-zinc-500 italic text-xs">카테고리를 선택하고 실행하면 Prompt가 표시됩니다.</div>`;
            document.getElementById('python-output').innerHTML = `<div class="text-zinc-500 italic text-xs">여기에 Python 스타일 출력이 표시됩니다.</div>`;
            document.getElementById('execution-info').textContent = '';
        }

        function renderDynamicForm(category) {
            const container = document.getElementById('dynamic-input-form');
            const config = categoryConfig[category];
            if (!config) return;

            let html = '';

            config.inputs.forEach(input => {
                html += `
                    <div>
                        <label class="text-xs text-zinc-500 block mb-1.5">${input.label}</label>
                        <input id="input-${input.id}" type="${input.type}" value="${input.value}" 
                               class="w-full bg-zinc-950 border border-white/20 rounded-2xl px-4 py-3 text-sm focus:outline-none focus:border-indigo-500">
                    </div>
                `;
            });

            container.innerHTML = html;
            document.getElementById('category-label').textContent = config.description;
            document.getElementById('run-button-text').textContent = `${config.label} 실행`;
        }

        function runPipelineDemo() {
            const config = categoryConfig[currentCategory];
            if (!config || !config.run) {
                alert('해당 카테고리의 시뮬레이션이 아직 구현되지 않았습니다.');
                return;
            }
            config.run();
        }

        // ==================== Category Runners ====================

        function runPart01Basic() {
            const location = document.getElementById('input-location')?.value || '창고 출입구';
            const timestamp = document.getElementById('input-timestamp')?.value || '02:47';
            const detections = document.getElementById('input-detections')?.value || 'person 2명';

            const prompt = `System: 당신은 AI CCTV 보안 분석 시스템입니다.\nUser: ${timestamp}에 ${location}에서 ${detections}이 탐지됐습니다. 위험도를 분석해주세요.`;

            const result = {
                risk_level: "주의",
                reason: `${location}에서 심야 시간대에 다수 인원 탐지`,
                action: "근처 순찰 강화 및 추가 영상 확인 필요"
            };

            updateOutputs(prompt, result, 'Part01 - Basic Completion');
        }

        function runPart02LCEL() {
            const frameId = document.getElementById('input-frame_id')?.value || '42';
            const location = document.getElementById('input-location')?.value || '주차장 A구역';
            const detections = document.getElementById('input-detections')?.value || 'person:2, car:1';

            const prompt = `System: 당신은 AI CCTV 보안 관제 전문가입니다.\nHuman: 프레임 ${frameId} | ${location}\n${detections}\n\n위험도, 이유, 조치사항을 JSON으로 반환하세요.`;

            const result = {
                frame_id: parseInt(frameId),
                location: location,
                risk_level: "위험",
                reason: "심야 시간대 다수 인원 + 차량 동반 탐지",
                action: "즉시 경비 출동 및 경찰 신고 권장"
            };

            updateOutputs(prompt, result, 'Part02 - LCEL + JsonOutputParser');
        }

        function runPart03RAG() {
            const query = document.getElementById('input-query')?.value || '새벽에 창고에서 침입 의심 사례 알려줘';

            const prompt = `System: 당신은 보안 전문가입니다.\n\n[Retrieved Context]\n- 2024-11-20 02:31 창고 출입구 침입 (person:2)\n- 2025-01-08 03:15 공장 외곽 침입 (person:3, car:2)\n\nUser: ${query}`;

            const result = {
                answer: "과거 유사 사례 2건 발견. 대부분 새벽 시간대 창고/공장 지역에서 발생했습니다.",
                sources: ["log_001", "log_002"],
                confidence: "high"
            };

            updateOutputs(prompt, result, 'Part03 - RAG Pipeline');
        }

        function runPart04Diarization() {
            const audioName = document.getElementById('input-audio_name')?.value || '20260526_All_units.wav';

            const prompt = `[Whisper + pyannote Pipeline]\nAudio: ${audioName}\n→ STT + Speaker Diarization 실행`;

            const result = [
                { speaker: "민욱 (Control)", start: "00:07.8", end: "00:12.3", text: "3번 프레임 창고 출입구에서 person 2명 확인" },
                { speaker: "주완 (Unit 3)", start: "00:13.1", end: "00:18.9", text: "차량 1대 동반. 위험 상황으로 판단" }
            ];

            updateOutputs(prompt, result, 'Part04 - Speaker Diarization');
        }

        function runPart04Vision() {
            const imageDesc = document.getElementById('input-image_desc')?.value || '주차장에서 두 사람이 차량 주변을 배회하는 모습';

            const prompt = `System: 당신은 보안 영상 분석 전문가입니다.\nUser: [이미지] ${imageDesc}\n\n이 장면을 분석하고 위험도를 판단하세요.`;

            const result = {
                scene: "주차장 야간 장면",
                objects: ["person", "vehicle"],
                risk_level: "주의",
                reason: "심야 시간대에 차량 주변을 배회하는 두 사람",
                recommendation: "추가 CCTV 확대 및 순찰 요청"
            };

            updateOutputs(prompt, result, 'Part04 - Vision Analysis');
        }

        function updateOutputs(promptText, resultData, categoryName) {
            // Prompt
            document.getElementById('prompt-output').innerHTML = 
                `<pre class="whitespace-pre-wrap text-amber-300 text-xs leading-snug">${promptText}</pre>`;

            // Python-style output
            const pythonOutput = document.getElementById('python-output');
            
            let outputHTML = `<div class="text-emerald-400 mb-2">>>> pipeline.run()</div>`;

            if (Array.isArray(resultData)) {
                outputHTML += `<div class="text-zinc-400 mb-1"># Speaker Segments</div>`;
                resultData.forEach((seg, i) => {
                    outputHTML += `<div class="pl-2 text-xs">[{i}] {seg.speaker} | {seg.start} ~ {seg.end}</div>`;
                    outputHTML += `<div class="pl-6 text-emerald-200 text-xs">"{seg.text}"</div>`;
                });
            } else {
                outputHTML += `<pre class="text-emerald-300 text-xs leading-relaxed">${JSON.stringify(resultData, null, 2)}</pre>`;
            }

            outputHTML += `<div class="text-zinc-500 text-[10px] mt-3">✓ Execution completed in 0.87s</div>`;
            pythonOutput.innerHTML = outputHTML;

            document.getElementById('execution-info').innerHTML = 
                `<span class="text-emerald-400">●</span> ${categoryName} • simulated`;
        }

        // Initialize demo with default category
        function initAdvancedDemo() {
            // Set initial category
            const firstTab = document.querySelector('.category-tab');
            if (firstTab) {
                firstTab.classList.add('bg-white', 'text-zinc-900');
            }
            renderDynamicForm('part01-basic');
        }

        // Boot enhancement
        const originalInit = window.onload;
        window.onload = function() {
            if (originalInit) originalInit();
            initAdvancedDemo();
        };
        // ==================== PYODIDE RUNNER (B-2 Ambitious Version) ====================
        async function runPythonViaPyodide() {
            const codeEditor = document.getElementById('python-code-editor');
            const outputEl = document.getElementById('python-console-output');
            
            if (!codeEditor) return;

            const code = codeEditor.value.trim();
            if (!code) {
                outputEl.innerHTML = '<span class="text-red-400">코드가 비어있습니다.</span>';
                return;
            }

            outputEl.innerHTML = '<span class="text-yellow-400">Pyodide에서 실행 중...</span>';

            const result = await runPythonCode(code);

            if (result.success) {
                outputEl.innerHTML = result.output
                    .split('\n')
                    .map(line => `<div>${escapeHtml(line)}</div>`)
                    .join('');
            } else {
                outputEl.innerHTML = `<span class="text-red-400">에러:\n${escapeHtml(result.output)}</span>`;
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // 카테고리별 기본 Python 코드 (실제 프로젝트 코드에서 영감을 받아 단순화)
        const defaultPythonCodes = {
            'part01-basic': `# Part01 - Basic Chat Completion 시뮬레이션
messages = [
    {"role": "system", "content": "당신은 AI CCTV 보안 분석 시스템입니다."},
    {"role": "user", "content": "새벽 2시 창고 출입구에서 사람 2명 탐지"}
]

print("=== Part01 Basic Completion ===")
print("Messages:", messages)
print()
print(">>> LLM 응답 (모의)")
print({"risk_level": "주의", "reason": "심야 다수 인원 탐지", "action": "순찰 강화"} )`,

            'part02-lcel': `# Part02 - LCEL 스타일 체인 시뮬레이션
from typing import Dict

def format_detections(data: Dict) -> Dict:
    return {
        "frame_id": data["frame_id"],
        "detections_text": f"- {data['detections']} 탐지"
    }

class SimpleChain:
    def __init__(self, steps):
        self.steps = steps
    
    def invoke(self, input_data):
        result = input_data
        for step in self.steps:
            result = step(result)
        return result

chain = SimpleChain([format_detections, lambda x: {"analysis": x}])

input_data = {"frame_id": 42, "detections": "person:2"}
result = chain.invoke(input_data)

print("=== Part02 LCEL Chain ===")
print(result)`,

            'part03-rag': `# Part03 - 간단한 RAG 시뮬레이션
documents = [
    "새벽 2시 창고 출입구 침입 (person:2)",
    "오후 2시 주차장 정상 이용객"
]

def retrieve(query):
    # 간단한 키워드 매칭 (실제로는 Vector Search)
    return [doc for doc in documents if "새벽" in doc or "침입" in query]

def generate_answer(context, query):
    return f"검색된 문서: {len(context)}개\\n답변: 과거 새벽 침입 사례가 있습니다."

query = "새벽 창고 침입 사례"
context = retrieve(query)
answer = generate_answer(context, query)

print("=== Part03 RAG Pipeline ===")
print("Query:", query)
print("Retrieved:", context)
print("Final Answer:", answer)`,

            'part04-diarization': `# Part04 - Speaker Diarization 결과 처리 시뮬레이션
segments = [
    {"speaker": "민욱 (Control)", "start": 7.8, "end": 12.3, "text": "3번 프레임 창고 출입구 확인"},
    {"speaker": "주완 (Unit 3)", "start": 13.1, "end": 18.9, "text": "차량 동반. 위험 상황"}
]

print("=== Part04 Speaker Diarization ===")
for seg in segments:
    print(f"[{seg['speaker']}] {seg['start']:.1f}s ~ {seg['end']:.1f}s")
    print(f"    {seg['text']}")
    print()`,

            'part04-vision': `# Part04 - Vision Analysis 시뮬레이션
image_analysis = {
    "objects": ["person", "vehicle"],
    "risk_level": "주의",
    "description": "야간 주차장에서 두 사람이 차량 주변 배회"
}

print("=== Part04 Vision Analysis ===")
print(image_analysis)`
        };

        function selectCategory(category) {
            currentCategory = category;
            
            document.querySelectorAll('.category-tab').forEach(tab => {
                if (tab.dataset.category === category) {
                    tab.classList.add('active', 'bg-white', 'text-zinc-900');
                    tab.classList.remove('bg-zinc-800');
                } else {
                    tab.classList.remove('active', 'bg-white', 'text-zinc-900');
                    tab.classList.add('bg-zinc-800');
                }
            });

            // 기본 Python 코드 로드
            const editor = document.getElementById('python-code-editor');
            if (editor && defaultPythonCodes[category]) {
                editor.value = defaultPythonCodes[category];
            }

            const outputEl = document.getElementById('python-console-output');
            if (outputEl) {
                outputEl.innerHTML = '<div class="text-zinc-500 italic">위 코드를 수정한 후 "Python 코드 실행" 버튼을 누르세요.</div>';
            }
        }

        function resetToDefaultCode() {
            const editor = document.getElementById('python-code-editor');
            if (editor && defaultPythonCodes[currentCategory]) {
                editor.value = defaultPythonCodes[currentCategory];
            }
        }

        // 초기화 시 Pyodide 미리 로드 + 기본 카테고리 설정
        async function initPyodideDemo() {
            // Pyodide 백그라운드 로드 시작
            loadPyodideIfNeeded();

            // 첫 번째 카테고리 기본 코드 로드
            setTimeout(() => {
                const editor = document.getElementById('python-code-editor');
                if (editor && defaultPythonCodes['part01-basic']) {
                    editor.value = defaultPythonCodes['part01-basic'];
                }
                
                // 첫 번째 탭 활성화
                const firstTab = document.querySelector('.category-tab');
                if (firstTab) {
                    firstTab.classList.add('bg-white', 'text-zinc-900');
                }
            }, 300);
        }

        // 기존 init 함수에 추가
        const originalWindowOnload = window.onload;
        window.onload = function() {
            if (originalWindowOnload) originalWindowOnload();
            initPyodideDemo();
        };
        // ==================== END PYODIDE B-2 (ambitious textarea state preserved) ====================

        // ==================== demo.js 호환 레이어 (사용자 요청: demo.js 기능도 HTML에 구현) ====================
        // demo.js가 <script src>로 로드되었으므로, 그 안에 있는 함수(loadDemoCategory, runPythonViaPyodide 등)를
        // HTML의 onclick에서 그대로 쓸 수 있게 추가 노출 + 현재 인라인 구현과 공존.
        (function exposeDemoJsApi() {
            // demo.js가 제공하는 함수를 우선 사용, 없으면 현재 인라인 함수로 폴백
            window.runCurrentPyodideCode = window.runCurrentPyodideCode || runPythonViaPyodide;

            window.loadDemoCategory = function(category) {
                if (typeof loadDemoCategory === 'function' && loadDemoCategory !== window.loadDemoCategory) {
                    // demo.js 버전이 이미 있으면 사용 (demo.js가 나중에 로드된 경우)
                    return loadDemoCategory(category);
                }
                // 그렇지 않으면 현재 인라인의 selectCategory 동작 모방
                if (typeof selectCategory === 'function') {
                    selectCategory(category);
                } else if (typeof defaultPythonCodes !== 'undefined') {
                    const editor = document.getElementById('python-code-editor');
                    if (editor && defaultPythonCodes[category]) {
                        editor.value = defaultPythonCodes[category];
                    }
                }
            };

            // demo.js의 DEMO_CATEGORIES 별칭도 제공 (하위 호환)
            if (typeof defaultPythonCodes !== 'undefined') {
                window.DEMO_CATEGORIES = defaultPythonCodes;
            }

            console.log('%c[Pyodide] demo.js 호환 API (runCurrentPyodideCode, loadDemoCategory) 노출 완료', 'color:#64748b');
        })();
        // ==================== END demo.js compat layer ====================
    </script>
</body>
</html>
